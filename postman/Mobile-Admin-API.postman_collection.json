{
  "info": {
    "_postman_id": "a1b2c3d4-mobile-admin-api",
    "name": "Mobile Admin API (Node + MySQL)",
    "description": "REST API for the Vite admin panel (`server/`). Base path: `/api`.\n\n**Auth:** `POST /api/auth/login` returns `token`. Collection uses Bearer `{{token}}` (set automatically by Login test script).\n\n**Admin users:** Laravel `users` where `role = '1'` OR `role_id` is set.\n\n**Local default:** `baseUrl` = `http://127.0.0.1:4000`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://127.0.0.1:4000" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  try {",
                  "    const j = pm.response.json();",
                  "    if (j.token) { pm.collectionVariables.set('token', j.token); }",
                  "  } catch (e) {}",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"your-password\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Returns `{ token, user }`. Saves `token` to collection variable."
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/auth/me",
            "description": "Current user from JWT (`sub` = user id)."
          }
        }
      ]
    },
    {
      "name": "Profiles",
      "item": [
        {
          "name": "List profiles (mobile users 2,3,4)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/profiles"
          }
        },
        {
          "name": "Patch profile",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"is_active\": true,\n  \"approval_status\": \"approved\",\n  \"name\": \"\",\n  \"email\": \"\",\n  \"phone\": \"\"\n}"
            },
            "url": "{{baseUrl}}/api/profiles/1",
            "description": "Send only fields to change. `approval_status`: `approved` sets `verified=1`."
          }
        },
        {
          "name": "All users (chat picker)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/profiles/all-users"
          }
        }
      ]
    },
