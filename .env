# MySQL — used by the Node API (server/db.js) and listed here for one .env file
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=binalsheikh_db
DB_USERNAME=root
DB_PASSWORD=

# Node admin API (server/index.js)
PORT=4000
JWT_SECRET=change-this-to-a-long-random-string-in-production
PUBLIC_BASE_URL=http://127.0.0.1:4000

# Production build only: full API URL if frontend is not served behind same proxy
# VITE_API_URL=https://your-api.example.com
